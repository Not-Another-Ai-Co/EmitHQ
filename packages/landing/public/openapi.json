      "post": {
        "operationId": "createPortalSession",
        "summary": "Create Stripe customer portal session",
        "description": "Returns a URL to the Stripe customer portal for subscription management.",
        "tags": ["Billing"],
        "responses": {
          "200": {
            "description": "Portal URL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": { "url": { "type": "string", "format": "uri" } }
                    }
                  }
                }
              }
            }
          },
          "412": {
            "description": "No Stripe customer (never subscribed)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    }
